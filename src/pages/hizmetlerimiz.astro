---
import PageLayout from '../layout/page.layout.astro';
---

<PageLayout>
    <!-- HERO SECTION -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 py-24 lg:py-32">
        <!-- Background Elements -->
        <div class="absolute inset-0">
            <div
                class="absolute top-20 left-20 h-32 w-32 animate-pulse rounded-full bg-gradient-to-r from-blue-400 to-purple-400 opacity-20 blur-3xl">
            </div>
            <div
                class="absolute right-20 bottom-20 h-40 w-40 animate-pulse rounded-full bg-gradient-to-r from-purple-400 to-pink-400 opacity-20 blur-3xl delay-1000">
            </div>
        </div>

        <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
            <div class="space-y-8">
                <div
                    class="inline-flex items-center rounded-full bg-white/20 px-4 py-2 text-sm font-medium text-white/90 backdrop-blur-sm">
                    <svg
                        class="mr-2 h-4 w-4"
                        fill="currentColor"
                        viewBox="0 0 24 24">
                        <path d="M13 3L4 14h7l-1 8 9-11h-7l1-8z"></path>
                    </svg>
                    Dijital Çözümler
                </div>

                <h1
                    class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
                    <span class="block">Hizmetlerimiz</span>
                    <span
                        class="block bg-gradient-to-r from-yellow-300 via-orange-300 to-pink-300 bg-clip-text text-transparent">
                        Kaliteli Çözümler
                    </span>
                </h1>

                <p
                    class="mx-auto max-w-2xl text-xl leading-relaxed text-blue-100">
                    Web tasarımından mobil uygulamalara, e-ticaret sitelerinden
                    kurumsal yazılımlara kadar ihtiyacınız olan tüm dijital
                    çözümleri sunuyoruz.
                </p>
            </div>
        </div>
    </section>

    <!-- HİZMETLER SECTION -->
    <section class="relative bg-white py-24 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <!-- Ana Hizmetler -->
            <div class="mb-20 text-center">
                <h2
                    class="mt-6 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Size Özel Çözümler Sunuyoruz
                </h2>
                <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
                    Modern teknolojiler kullanarak işinize değer katacak dijital
                    çözümler geliştiriyoruz
                </p>
            </div>

            <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
                <!-- Web Tasarım & Geliştirme -->
                <div class="group relative">
                    <div
                        class="relative h-full overflow-hidden rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 p-8 shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl">
                        <div
                            class="absolute -top-8 -right-8 h-32 w-32 rounded-full bg-white/10">
                        </div>
                        <div class="relative flex flex-col">
                            <div
                                class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-xl bg-white/20 backdrop-blur-sm">
                                <svg
                                    class="h-8 w-8 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    ></path>
                                </svg>
                            </div>
                            <h3 class="mb-4 text-xl font-bold text-white">
                                Web Tasarım & Geliştirme
                            </h3>
                            <p class="mb-6 text-blue-100">
                                Modern, responsive ve kullanıcı dostu web
                                siteleri tasarlayıp geliştiriyoruz.
                            </p>
                            <ul class="flex-1 space-y-2 text-sm text-blue-100">
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Responsive Tasarım
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    SEO Optimizasyonu
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Hızlı Yükleme
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Modern Teknolojiler
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- E-Ticaret Çözümleri -->
                <div class="group relative">
                    <div
                        class="relative h-full overflow-hidden rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 p-8 shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl">
                        <div
                            class="absolute -top-8 -right-8 h-32 w-32 rounded-full bg-white/10">
                        </div>
                        <div class="relative flex flex-col">
                            <div
                                class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-xl bg-white/20 backdrop-blur-sm">
                                <svg
                                    class="h-8 w-8 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 3h2l.4 2M7 13h10l4-8H5.4m0 0L7 3H3m4 10L5 21l1.5-1.5M9 19.5h9.5"
                                    ></path>
                                </svg>
                            </div>
                            <h3 class="mb-4 text-xl font-bold text-white">
                                E-Ticaret Çözümleri
                            </h3>
                            <p class="mb-6 text-emerald-100">
                                Güvenli ve kullanıcı dostu e-ticaret
                                platformları ile online satışlarınızı artırın.
                            </p>
                            <ul
                                class="flex-1 space-y-2 text-sm text-emerald-100">
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Güvenli Ödeme Sistemi
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Stok Yönetimi
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Sipariş Takibi
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Multi-Platform Entegrasyon
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Mobil Uygulama Geliştirme -->
                <div class="group relative">
                    <div
                        class="relative h-full overflow-hidden rounded-2xl bg-gradient-to-br from-purple-500 to-pink-600 p-8 shadow-xl transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl">
                        <div
                            class="absolute -top-8 -right-8 h-32 w-32 rounded-full bg-white/10">
                        </div>
                        <div class="relative flex flex-col">
                            <div
                                class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-xl bg-white/20 backdrop-blur-sm">
                                <svg
                                    class="h-8 w-8 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                                    ></path>
                                </svg>
                            </div>
                            <h3 class="mb-4 text-xl font-bold text-white">
                                Mobil Uygulama Geliştirme
                            </h3>
                            <p class="mb-6 text-purple-100">
                                iOS ve Android platformları için kullanıcı
                                deneyimi odaklı mobil uygulamalar.
                            </p>
                            <ul
                                class="flex-1 space-y-2 text-sm text-purple-100">
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    iOS & Android
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Cross-Platform
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    Push Notification
                                </li>
                                <li class="flex items-center">
                                    <svg
                                        class="mr-2 h-4 w-4 text-green-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20">
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                    API Entegrasyonu
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- DETAYLI HİZMETLER SECTION -->
    <section class="relative bg-gray-50 py-24 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mb-16 text-center">
                <h2
                    class="mt-6 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Kapsamlı Dijital Çözümler
                </h2>
                <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
                    İşinizin her alanında ihtiyaç duyabileceğiniz tüm dijital
                    hizmetleri sunuyoruz
                </p>
            </div>

            <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
                <!-- Kurumsal Web Siteleri -->
                <div
                    class="group relative overflow-hidden rounded-xl bg-gradient-to-br from-blue-50 to-indigo-100 p-6 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
                    <div
                        class="absolute -top-4 -right-4 h-20 w-20 rounded-full bg-blue-200/30">
                    </div>
                    <div class="relative">
                        <div
                            class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-blue-500 shadow-md">
                            <svg
                                class="h-6 w-6 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h1a1 1 0 011 1v5m-4 0h4"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="mb-2 text-lg font-semibold text-gray-800">
                            Kurumsal Web Siteleri
                        </h3>
                        <p class="text-gray-700">
                            Markanızı en iyi şekilde yansıtan, profesyonel
                            kurumsal web siteleri.
                        </p>
                    </div>
                </div>

                <!-- Landing Page -->
                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg">
                    <div
                        class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-green-100">
                        <svg
                            class="h-6 w-6 text-green-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-lg font-semibold text-gray-900">
                        Landing Page
                    </h3>
                    <p class="text-gray-600">
                        Yüksek dönüşüm oranları için optimize edilmiş etkili
                        tanıtım sayfaları.
                    </p>
                </div>

                <!-- Blog Siteleri -->
                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg">
                    <div
                        class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100">
                        <svg
                            class="h-6 w-6 text-purple-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-lg font-semibold text-gray-900">
                        Blog & İçerik Siteleri
                    </h3>
                    <p class="text-gray-600">
                        SEO dostu blog platformları ve içerik yönetim
                        sistemleri.
                    </p>
                </div>

                <!-- Portfolio Siteleri -->
                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg">
                    <div
                        class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-yellow-100">
                        <svg
                            class="h-6 w-6 text-yellow-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-lg font-semibold text-gray-900">
                        Portfolio Siteleri
                    </h3>
                    <p class="text-gray-600">
                        Çalışmalarınızı en etkileyici şekilde sergileyen
                        portfolio web siteleri.
                    </p>
                </div>

                <!-- CRM Sistemleri -->
                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg">
                    <div
                        class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-red-100">
                        <svg
                            class="h-6 w-6 text-red-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-lg font-semibold text-gray-900">
                        CRM Sistemleri
                    </h3>
                    <p class="text-gray-600">
                        Müşteri ilişkilerini yönetmek için özel geliştirilmiş
                        CRM çözümleri.
                    </p>
                </div>

                <!-- API Geliştirme -->
                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg">
                    <div
                        class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100">
                        <svg
                            class="h-6 w-6 text-indigo-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-lg font-semibold text-gray-900">
                        API Geliştirme
                    </h3>
                    <p class="text-gray-600">
                        Sistemler arası entegrasyon için güvenli ve hızlı API
                        çözümleri.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- SÜREÇ SECTION -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-blue-900 to-purple-900 py-24 lg:py-32">
        <div class="absolute inset-0">
            <div
                class="absolute top-20 left-20 h-32 w-32 animate-pulse rounded-full bg-gradient-to-r from-blue-500 to-purple-500 opacity-20 blur-3xl">
            </div>
            <div
                class="absolute right-20 bottom-20 h-40 w-40 animate-pulse rounded-full bg-gradient-to-r from-purple-500 to-pink-500 opacity-20 blur-3xl delay-1000">
            </div>
        </div>

        <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mb-16 text-center">
                <h2
                    class="mt-6 text-3xl font-bold tracking-tight text-white sm:text-4xl">
                    Nasıl Çalışıyoruz?
                </h2>
                <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
                    Projelerinizi hayata geçirirken izlediğimiz profesyonel
                    adımlar
                </p>
            </div>

            <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
                <!-- Adım 1 -->
                <div class="group relative">
                    <div
                        class="flex h-full flex-col items-center rounded-2xl bg-white/10 p-8 text-center backdrop-blur-sm transition-all duration-300 hover:-translate-y-2 hover:bg-white/20">
                        <div
                            class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-blue-500 text-2xl font-bold text-white">
                            1
                        </div>
                        <h3 class="mb-4 text-xl font-bold text-white">
                            Analiz
