---
import PageLayout from '../../layout/page.layout.astro';
---

<PageLayout>
    <!-- HERO SECTION -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 py-24 lg:py-32">
        <!-- Background Animation Elements -->
        <div class="absolute inset-0">
            <div
                class="absolute top-10 left-10 h-20 w-20 animate-pulse rounded-full bg-white opacity-10">
            </div>
            <div
                class="absolute right-10 bottom-10 h-16 w-16 animate-pulse rounded-full bg-white opacity-10 delay-1000">
            </div>
            <div
                class="absolute top-1/2 left-1/4 h-12 w-12 animate-pulse rounded-full bg-white opacity-10 delay-500">
            </div>
            <div
                class="absolute top-20 right-1/4 h-24 w-24 animate-bounce rounded-full bg-white opacity-5 delay-300">
            </div>
        </div>

        <!-- Geometric Patterns -->
        <div class="absolute inset-0 opacity-10">
            <div
                class="animate-spin-slow absolute top-16 left-16 h-32 w-32 rotate-45 border-2 border-white">
            </div>
            <div
                class="absolute right-16 bottom-16 h-24 w-24 rotate-12 animate-pulse border-2 border-white">
            </div>
        </div>

        <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
            <div class="space-y-8">
                <div
                    class="inline-flex items-center rounded-full bg-white/20 px-4 py-2 text-sm font-medium text-white/90 backdrop-blur-sm">
                    <span class="mr-2">🏆</span>
                    Başarı Hikayeleri
                </div>

                <h1
                    class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
                    <span class="block">Referanslarımız</span>
                    <span
                        class="block bg-gradient-to-r from-yellow-300 via-orange-300 to-pink-300 bg-clip-text text-transparent">
                        Güven Yaratan Projeler
                    </span>
                </h1>

                <p
                    class="mx-auto max-w-2xl text-xl leading-relaxed text-blue-100">
                    Farklı sektörlerden müşterilerimizle gerçekleştirdiğimiz
                    başarılı projeler. Her biri benzersiz çözümler ve mükemmel
                    sonuçlar.
                </p>
            </div>
        </div>
    </section>

    <!-- FEATURED PROJECTS SECTION -->
    <section class="py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
                <h2
                    class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Öne Çıkan Projelerimiz
                </h2>
                <p class="mt-6 text-lg leading-8 text-gray-600">
                    Son dönemde tamamladığımız ve müşterilerimizin hedeflerine
                    ulaşmasını sağlayan projeler
                </p>
            </div>

            <div class="mx-auto mt-16 max-w-2xl lg:max-w-none">
                <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
                    <!-- E-TİCARET PROJESİ -->
                    <a
                        href="/referanslarimiz/techshop-eticaret"
                        class="group relative block overflow-hidden rounded-2xl bg-white shadow-lg transition-all duration-300 hover:shadow-xl">
                        <div
                            class="aspect-[16/9] bg-gradient-to-br from-blue-50 to-indigo-100 p-8">
                            <div class="flex h-full flex-col justify-between">
                                <div class="flex items-center justify-between">
                                    <div class="rounded-lg bg-indigo-600 p-3">
                                        <svg
                                            class="h-6 w-6 text-white"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke-width="1.5"
                                            stroke="currentColor">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119.993z"
                                            ></path>
                                        </svg>
                                    </div>
                                    <span
                                        class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800"
                                        >Tamamlandı</span
                                    >
                                </div>
                                <div class="space-y-2">
                                    <h3
                                        class="text-2xl font-bold text-gray-900">
                                        TechShop E-ticaret
                                    </h3>
                                    <p class="text-gray-600">
                                        Modern e-ticaret platformu
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="space-y-4">
                                <p class="text-gray-600">
                                    Elektronik ürünler satan bir şirket için
                                    geliştirdiğimiz modern e-ticaret platformu.
                                    Gelişmiş ödeme sistemi, stok yönetimi ve
                                    müşteri paneli.
                                </p>
                                <div class="grid grid-cols-2 gap-4 text-sm">
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Süre:</span
                                        >
                                        <span class="text-gray-600"
                                            >8 hafta</span
                                        >
                                    </div>
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Kategori:</span
                                        >
                                        <span class="text-gray-600"
                                            >E-ticaret</span
                                        >
                                    </div>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <span
                                        class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800"
                                        >React</span
                                    >
                                    <span
                                        class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-800"
                                        >Node.js</span
                                    >
                                    <span
                                        class="rounded-full bg-purple-100 px-3 py-1 text-xs font-medium text-purple-800"
                                        >MongoDB</span
                                    >
                                </div>
                                <div
                                    class="flex items-center justify-between pt-2">
                                    <span
                                        class="text-sm font-medium text-indigo-600 group-hover:text-indigo-800">
                                        Detayları Görüntüle
                                    </span>
                                    <svg
                                        class="h-4 w-4 text-indigo-600 transition-all group-hover:translate-x-1 group-hover:text-indigo-800"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- KURUMSAL WEB SİTESİ -->
                    <a
                        href="/referanslarimiz/ozyurt-insaat"
                        class="group relative block overflow-hidden rounded-2xl bg-white shadow-lg transition-all duration-300 hover:shadow-xl">
                        <div
                            class="aspect-[16/9] bg-gradient-to-br from-purple-50 to-pink-100 p-8">
                            <div class="flex h-full flex-col justify-between">
                                <div class="flex items-center justify-between">
                                    <div class="rounded-lg bg-purple-600 p-3">
                                        <svg
                                            class="h-6 w-6 text-white"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke-width="1.5"
                                            stroke="currentColor">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M2.25 21h19.5m-18-18v18m2.25-18v18m13.5-18v18m2.25-18v18M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.75m-.75 3h.75m-.75 3h.75m-3.75 3.75h.75m-.75-3-.75-3m.75 6v-6h-3V9m3 0V3"
                                            ></path>
                                        </svg>
                                    </div>
                                    <span
                                        class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800"
                                        >Tamamlandı</span
                                    >
                                </div>
                                <div class="space-y-2">
                                    <h3
                                        class="text-2xl font-bold text-gray-900">
                                        Özyurt İnşaat
                                    </h3>
                                    <p class="text-gray-600">
                                        Kurumsal web sitesi
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="space-y-4">
                                <p class="text-gray-600">
                                    İnşaat sektörünün öncü firmalarından biri
                                    için tasarladığımız modern ve kullanıcı
                                    dostu kurumsal web sitesi. Proje galerisi ve
                                    iletişim modülleri.
                                </p>
                                <div class="grid grid-cols-2 gap-4 text-sm">
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Süre:</span
                                        >
                                        <span class="text-gray-600"
                                            >6 hafta</span
                                        >
                                    </div>
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Kategori:</span
                                        >
                                        <span class="text-gray-600"
                                            >Kurumsal</span
                                        >
                                    </div>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <span
                                        class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800"
                                        >WordPress</span
                                    >
                                    <span
                                        class="rounded-full bg-orange-100 px-3 py-1 text-xs font-medium text-orange-800"
                                        >PHP</span
                                    >
                                    <span
                                        class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-800"
                                        >MySQL</span
                                    >
                                </div>
                                <div
                                    class="flex items-center justify-between pt-2">
                                    <span
                                        class="text-sm font-medium text-purple-600 group-hover:text-purple-800">
                                        Detayları Görüntüle
                                    </span>
                                    <svg
                                        class="h-4 w-4 text-purple-600 transition-all group-hover:translate-x-1 group-hover:text-purple-800"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- MOBİL UYGULAMA -->
                    <a
                        href="/referanslarimiz/fitlife-app"
                        class="group relative block overflow-hidden rounded-2xl bg-white shadow-lg transition-all duration-300 hover:shadow-xl">
                        <div
                            class="aspect-[16/9] bg-gradient-to-br from-green-50 to-emerald-100 p-8">
                            <div class="flex h-full flex-col justify-between">
                                <div class="flex items-center justify-between">
                                    <div class="rounded-lg bg-emerald-600 p-3">
                                        <svg
                                            class="h-6 w-6 text-white"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke-width="1.5"
                                            stroke="currentColor">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"
                                            ></path>
                                        </svg>
                                    </div>
                                    <span
                                        class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800"
                                        >Devam Ediyor</span
                                    >
                                </div>
                                <div class="space-y-2">
                                    <h3
                                        class="text-2xl font-bold text-gray-900">
                                        FitLife App
                                    </h3>
                                    <p class="text-gray-600">
                                        Fitness mobil uygulaması
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="space-y-4">
                                <p class="text-gray-600">
                                    Kişisel antrenörlük hizmeti veren bir şirket
                                    için geliştirdiğimiz kapsamlı fitness
                                    uygulaması. Antrenman planları, beslenme
                                    takibi ve ilerleme raporları.
                                </p>
                                <div class="grid grid-cols-2 gap-4 text-sm">
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Süre:</span
                                        >
                                        <span class="text-gray-600"
                                            >12 hafta</span
                                        >
                                    </div>
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Kategori:</span
                                        >
                                        <span class="text-gray-600"
                                            >Mobil App</span
                                        >
                                    </div>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <span
                                        class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800"
                                        >React Native</span
                                    >
                                    <span
                                        class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-800"
                                        >Firebase</span
                                    >
                                    <span
                                        class="rounded-full bg-red-100 px-3 py-1 text-xs font-medium text-red-800"
                                        >Redux</span
                                    >
                                </div>
                                <div
                                    class="flex items-center justify-between pt-2">
                                    <span
                                        class="text-sm font-medium text-purple-600 group-hover:text-purple-800">
                                        Detayları Görüntüle
                                    </span>
                                    <svg
                                        class="h-4 w-4 text-purple-600 transition-all group-hover:translate-x-1 group-hover:text-purple-800"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- DİJİTAL PAZARLAMA -->
                    <a
                        href="/referanslarimiz/moda-boutique"
                        class="group relative block overflow-hidden rounded-2xl bg-white shadow-lg transition-all duration-300 hover:shadow-xl">
                        <div
                            class="aspect-[16/9] bg-gradient-to-br from-orange-50 to-red-100 p-8">
                            <div class="flex h-full flex-col justify-between">
                                <div class="flex items-center justify-between">
                                    <div class="rounded-lg bg-orange-600 p-3">
                                        <svg
                                            class="h-6 w-6 text-white"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke-width="1.5"
                                            stroke="currentColor">
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"
                                            ></path>
                                        </svg>
                                    </div>
                                    <span
                                        class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800"
                                        >Tamamlandı</span
                                    >
                                </div>
                                <div class="space-y-2">
                                    <h3
                                        class="text-2xl font-bold text-gray-900">
                                        Moda Boutique
                                    </h3>
                                    <p class="text-gray-600">
                                        Dijital pazarlama kampanyası
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="space-y-4">
                                <p class="text-gray-600">
                                    Kadın giyim mağazası için geliştirdiğimiz
                                    360° dijital pazarlama stratejisi. Social
                                    media, Google Ads ve influencer marketing
                                    entegrasyonu.
                                </p>
                                <div class="grid grid-cols-2 gap-4 text-sm">
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Süre:</span
                                        >
                                        <span class="text-gray-600">4 ay</span>
                                    </div>
                                    <div>
                                        <span class="font-medium text-gray-900"
                                            >Kategori:</span
                                        >
                                        <span class="text-gray-600"
                                            >Pazarlama</span
                                        >
                                    </div>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <span
                                        class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800"
                                        >Google Ads</span
                                    >
                                    <span
                                        class="rounded-full bg-pink-100 px-3 py-1 text-xs font-medium text-pink-800"
                                        >Instagram</span
                                    >
                                    <span
                                        class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-800"
                                        >Analytics</span
                                    >
                                </div>
                                <div
                                    class="flex items-center justify-between pt-2">
                                    <span
                                        class="text-sm font-medium text-purple-600 group-hover:text-purple-800">
                                        Detayları Görüntüle
                                    </span>
                                    <svg
                                        class="h-4 w-4 text-purple-600 transition-all group-hover:translate-x-1 group-hover:text-purple-800"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- CLIENT LOGOS SECTION -->
    <section class="bg-gray-50 py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
                <h2
                    class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Güvenen Müşterilerimiz
                </h2>
                <p class="mt-6 text-lg leading-8 text-gray-600">
                    Farklı sektörlerden 50+ müşteriyle başarılı projeler
                    gerçekleştirdik
                </p>
            </div>

            <div class="mx-auto mt-16 max-w-2xl lg:max-w-none">
                <div
                    class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-6">
                    <!-- Müşteri logoları için placeholder'lar -->
                    <div class="col-span-1 flex justify-center">
                        <div
                            class="flex h-20 w-32 items-center justify-center rounded-lg bg-white shadow-sm transition-all duration-200 hover:shadow-md">
                            <span class="text-lg font-bold text-gray-400"
                                >TechShop</span
                            >
                        </div>
                    </div>
                    <div class="col-span-1 flex justify-center">
                        <div
                            class="flex h-20 w-32 items-center justify-center rounded-lg bg-white shadow-sm transition-all duration-200 hover:shadow-md">
                            <span class="text-lg font-bold text-gray-400"
                                >Özyurt</span
                            >
                        </div>
                    </div>
                    <div class="col-span-1 flex justify-center">
                        <div
                            class="flex h-20 w-32 items-center justify-center rounded-lg bg-white shadow-sm transition-all duration-200 hover:shadow-md">
                            <span class="text-lg font-bold text-gray-400"
                                >FitLife</span
                            >
                        </div>
                    </div>
                    <div class="col-span-1 flex justify-center">
                        <div
                            class="flex h-20 w-32 items-center justify-center rounded-lg bg-white shadow-sm transition-all duration-200 hover:shadow-md">
                            <span class="text-lg font-bold text-gray-400"
                                >Moda Plus</span
                            >
                        </div>
                    </div>
                    <div class="col-span-1 flex justify-center">
                        <div
                            class="flex h-20 w-32 items-center justify-center rounded-lg bg-white shadow-sm transition-all duration-200 hover:shadow-md">
                            <span class="text-lg font-bold text-gray-400"
                                >Gıda Market</span
                            >
                        </div>
                    </div>
                    <div class="col-span-1 flex justify-center">
                        <div
                            class="flex h-20 w-32 items-center justify-center rounded-lg bg-white shadow-sm transition-all duration-200 hover:shadow-md">
                            <span class="text-lg font-bold text-gray-400"
                                >EduTech</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TESTIMONIALS SECTION -->
    <section class="py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
                <h2
                    class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Müşteri Yorumları
                </h2>
                <p class="mt-6 text-lg leading-8 text-gray-600">
                    Projelerimizi tamamlayan müşterilerimizin deneyimleri
                </p>
            </div>

            <div class="mx-auto mt-16 max-w-2xl lg:max-w-none">
                <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                    <!-- Testimonial 1 -->
                    <div
                        class="rounded-2xl bg-white p-8 shadow-lg transition-all duration-300 hover:shadow-xl">
                        <div
                            class="flex items-center space-x-1 text-yellow-400">
                            <svg
                                class="h-5 w-5"
                                fill="currentColor"
                                viewBox="0 0 20 20">
                                <path
                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                ></path>
                            </svg>
                            <svg
                                class="h-5 w-5"
                                fill="currentColor"
