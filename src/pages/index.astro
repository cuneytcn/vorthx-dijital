---
import Label from '../components/layout/page-header/label';
import PageLayout from '../layout/page.layout.astro';
---

<PageLayout>
    <!-- HERO SECTION -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 py-24 lg:py-32">
        <!-- Background Animation Elements -->
        <div class="absolute inset-0">
            <div
                class="absolute top-10 left-10 h-20 w-20 animate-pulse rounded-full bg-white opacity-10">
            </div>
            <div
                class="absolute right-10 bottom-10 h-16 w-16 animate-pulse rounded-full bg-white opacity-10 delay-1000">
            </div>
            <div
                class="absolute top-1/2 left-1/4 h-12 w-12 animate-pulse rounded-full bg-white opacity-10 delay-500">
            </div>
            <div
                class="absolute top-20 right-1/4 h-24 w-24 animate-bounce rounded-full bg-white opacity-5 delay-300">
            </div>
            <div
                class="absolute bottom-20 left-1/3 h-18 w-18 animate-bounce rounded-full bg-white opacity-5 delay-700">
            </div>
        </div>

        <!-- Geometric Patterns -->
        <div class="absolute inset-0 opacity-10">
            <div
                class="animate-spin-slow absolute top-16 left-16 h-32 w-32 rotate-45 border-2 border-white">
            </div>
            <div
                class="absolute right-16 bottom-16 h-24 w-24 rotate-12 animate-pulse border-2 border-white">
            </div>
            <div
                class="absolute top-1/3 right-1/3 h-16 w-16 animate-ping rounded-full bg-white delay-500">
            </div>
        </div>

        <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
            <!-- Main Content -->
            <div class="space-y-8">
                <div
                    class="inline-flex items-center rounded-full bg-white/20 px-4 py-2 text-sm font-medium text-white/90 backdrop-blur-sm">
                    <span class="mr-2 animate-pulse">🚀</span>
                    Projenizi Hayata Geçirme Zamanı
                </div>

                <h2
                    class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
                    <span class="block">Projenizi</span>
                    <span
                        class="block bg-gradient-to-r from-yellow-300 via-orange-300 to-pink-300 bg-clip-text text-transparent">
                        Hayata Geçirelim
                    </span>
                </h2>

                <p
                    class="mx-auto max-w-2xl text-xl leading-relaxed text-indigo-100">
                    Dijital dönüşüm yolculuğunuzda yanınızdayız. Hayalinizdeki
                    projeyi gerçeğe dönüştürmek için bugün ilk adımı atalım.
                </p>

                <!-- Feature Points -->
                <div class="mt-12 mb-12 grid grid-cols-1 gap-6 md:grid-cols-3">
                    <div
                        class="flex items-center justify-center space-x-3 text-white/90">
                        <div
                            class="flex h-8 w-8 items-center justify-center rounded-full bg-green-400">
                            <span class="text-sm">✓</span>
                        </div>
                        <span class="text-sm font-medium">Ücretsiz Analiz</span>
                    </div>
                    <div
                        class="flex items-center justify-center space-x-3 text-white/90">
                        <div
                            class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-400">
                            <span class="text-sm">⚡</span>
                        </div>
                        <span class="text-sm font-medium">Hızlı Başlangıç</span>
                    </div>
                    <div
                        class="flex items-center justify-center space-x-3 text-white/90">
                        <div
                            class="flex h-8 w-8 items-center justify-center rounded-full bg-purple-400">
                            <span class="text-sm">🎯</span>
                        </div>
                        <span class="text-sm font-medium">Garantili Kalite</span
                        >
                    </div>
                </div>
            </div>

            <!-- CTA Buttons -->
            <div
                class="flex flex-col items-center gap-6 sm:flex-row sm:justify-center">
                <a
                    href="/iletisim"
                    class="group hover:shadow-3xl relative inline-flex transform cursor-pointer overflow-hidden rounded-2xl bg-white px-10 py-5 text-lg font-semibold text-indigo-600 shadow-2xl transition-all duration-300 hover:scale-105 focus:ring-4 focus:ring-white/50 focus:ring-offset-2 focus:ring-offset-transparent focus:outline-none">
                    <div
                        class="absolute inset-0 bg-gradient-to-r from-yellow-400 to-orange-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                    </div>
                    <span
                        class="relative z-10 flex items-center transition-colors duration-300 group-hover:text-white">
                        <span class="mr-3 text-xl">📞</span>
                        Ücretsiz Görüşme
                        <svg
                            class="ml-2 h-5 w-5 transform transition-transform duration-300 group-hover:translate-x-1"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                        </svg>
                    </span>
                </a>

                <a
                    href="/hizmetlerimiz"
                    class="group relative inline-flex transform cursor-pointer rounded-2xl border-2 border-white px-10 py-5 text-lg font-semibold text-white transition-all duration-300 hover:scale-105 hover:bg-white hover:text-indigo-600 focus:ring-4 focus:ring-white/50 focus:ring-offset-2 focus:ring-offset-transparent focus:outline-none">
                    <span class="relative z-10 flex items-center">
                        <span class="mr-3 text-xl">🔍</span>
                        Hizmetleri İncele
                        <svg
                            class="ml-2 h-5 w-5 transform transition-transform duration-300 group-hover:translate-x-1"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                        </svg>
                    </span>
                </a>
            </div>

            <!-- Trust Indicators -->
            <div class="mt-16 border-t border-white/20 pt-8">
                <p class="mb-6 text-sm text-indigo-200">
                    Güvenilir partneriniz
                </p>
                <div
                    class="flex flex-wrap items-center justify-center gap-8 opacity-70">
                    <div class="flex items-center space-x-2 text-white/80">
                        <span class="text-yellow-300">⭐</span>
                        <span class="text-sm">5.0 Müşteri Puanı</span>
                    </div>
                    <div class="flex items-center space-x-2 text-white/80">
                        <span class="text-green-300">🛡️</span>
                        <span class="text-sm">SSL Güvenlik</span>
                    </div>
                    <div class="flex items-center space-x-2 text-white/80">
                        <span class="text-blue-300">📞</span>
                        <span class="text-sm">7/24 Destek</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- HİZMETLER SECTION -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-gray-50 via-blue-50 to-purple-50 py-24 lg:py-32">
        <!-- Background Decorations -->
        <div class="absolute inset-0">
            <div
                class="absolute top-20 -left-20 h-40 w-40 animate-pulse rounded-full bg-gradient-to-r from-blue-400 to-purple-500 opacity-10 blur-3xl">
            </div>
            <div
                class="absolute -right-20 bottom-20 h-60 w-60 animate-pulse rounded-full bg-gradient-to-r from-purple-400 to-pink-500 opacity-10 blur-3xl delay-1000">
            </div>
            <div
                class="absolute top-1/2 left-1/2 h-32 w-32 -translate-x-1/2 -translate-y-1/2 transform animate-pulse rounded-full bg-gradient-to-r from-indigo-400 to-cyan-500 opacity-5 blur-3xl delay-500">
            </div>
        </div>

        <!-- Floating Elements -->
        <div class="pointer-events-none absolute inset-0">
            <div
                class="absolute top-32 left-16 h-2 w-2 animate-bounce rounded-full bg-blue-400 delay-100">
            </div>
            <div
                class="absolute top-48 right-24 h-3 w-3 animate-bounce rounded-full bg-purple-400 delay-300">
            </div>
            <div
                class="absolute bottom-32 left-32 h-2 w-2 animate-bounce rounded-full bg-indigo-400 delay-700">
            </div>
            <div
                class="absolute right-16 bottom-48 h-3 w-3 animate-bounce rounded-full bg-pink-400 delay-1000">
            </div>
        </div>

        <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
            <div class="text-center">
                <Label
                    size="md"
                    variant="secondary"
                    icon=""
                    text="Hizmetlerimiz"
                />
                <h2
                    class="mt-6 bg-gradient-to-r from-gray-900 via-blue-800 to-purple-800 bg-clip-text text-3xl font-bold tracking-tight text-transparent sm:text-4xl">
                    Dijital Çözümlerimiz
                </h2>
                <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
                    Modern teknolojilerle işinizi geleceğe taşıyoruz. Her
                    projede yaratıcılık ve teknoloji bir araya geliyor.
                </p>

                <!-- Decorative Line -->
                <div class="mt-8 flex justify-center">
                    <div
                        class="h-1 w-24 rounded-full bg-gradient-to-r from-blue-500 to-purple-600">
                    </div>
                </div>
            </div>

            <div
                class="mt-20 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
                <!-- Web Tasarım -->
                <div
                    class="group relative overflow-hidden rounded-2xl bg-white p-8 shadow-lg transition-all duration-500 hover:-translate-y-3 hover:rotate-1 hover:shadow-2xl">
                    <div
                        class="absolute top-0 left-0 h-1 w-full bg-gradient-to-r from-blue-500 to-purple-600">
                    </div>
                    <div
                        class="absolute -top-10 -right-10 h-20 w-20 rounded-full bg-gradient-to-r from-blue-500 to-purple-600 opacity-10 transition-opacity duration-300 group-hover:opacity-20">
                    </div>
                    <div class="relative">
                        <div
                            class="mb-4 transform text-4xl transition-transform duration-300 group-hover:scale-110">
                            <svg
                                class="h-12 w-12 text-blue-600"
                                fill="currentColor"
                                viewBox="0 0 24 24">
                                <path
                                    d="M12 2L2 7v10c0 5.55 3.84 9.64 9 11 5.16-1.36 9-5.45 9-11V7l-10-5z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="mb-3 text-xl font-semibold text-gray-900 transition-colors duration-300 group-hover:text-blue-600">
                            Web Tasarım
                        </h3>
                        <p class="mb-4 text-gray-600">
                            Modern, responsive ve kullanıcı dostu web siteleri
                            tasarlıyoruz.
                        </p>
                        <ul class="mb-6 space-y-2 text-sm text-gray-500">
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-blue-400"
                                ></span>
                                Responsive Tasarım
                            </li>
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-blue-400"
                                ></span>
                                SEO Optimizasyonu
                            </li>
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-blue-400"
                                ></span>
                                Hızlı Yükleme
                            </li>
                        </ul>
                        <div
                            class="opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                            <a
                                href="/hizmetlerimiz#web"
                                class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800">
                                Detayları İncele
                                <svg
                                    class="ml-1 h-4 w-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- E-Ticaret -->
                <div
                    class="group relative overflow-hidden rounded-2xl bg-white p-8 shadow-lg transition-all duration-500 hover:-translate-y-3 hover:rotate-1 hover:shadow-2xl">
                    <div
                        class="absolute top-0 left-0 h-1 w-full bg-gradient-to-r from-green-500 to-emerald-600">
                    </div>
                    <div
                        class="absolute -top-10 -right-10 h-20 w-20 rounded-full bg-gradient-to-r from-green-500 to-emerald-600 opacity-10 transition-opacity duration-300 group-hover:opacity-20">
                    </div>
                    <div class="relative">
                        <div
                            class="mb-4 transform text-4xl transition-transform duration-300 group-hover:scale-110">
                            <svg
                                class="h-12 w-12 text-green-600"
                                fill="currentColor"
                                viewBox="0 0 24 24">
                                <path
                                    d="M7 4V2C7 1.45 7.45 1 8 1H16C16.55 1 17 1.45 17 2V4H20C20.55 4 21 4.45 21 5S20.55 6 20 6H19V19C19 20.1 18.1 21 17 21H7C5.9 21 5 20.1 5 19V6H4C3.45 6 3 5.55 3 5S3.45 4 4 4H7ZM9 3V4H15V3H9ZM7 6V19H17V6H7Z"
                                ></path>
                                <path d="M9 8V17H11V8H9ZM13 8V17H15V8H13Z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="mb-3 text-xl font-semibold text-gray-900 transition-colors duration-300 group-hover:text-green-600">
                            E-Ticaret
                        </h3>
                        <p class="mb-4 text-gray-600">
                            Güvenli ve kullanıcı dostu e-ticaret platformları
                            geliştiriyoruz.
                        </p>
                        <ul class="mb-6 space-y-2 text-sm text-gray-500">
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-green-400"
                                ></span>
                                Güvenli Ödeme
                            </li>
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-green-400"
                                ></span>
                                Stok Yönetimi
                            </li>
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-green-400"
                                ></span>
                                Mobil Uyumlu
                            </li>
                        </ul>
                        <div
                            class="opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                            <a
                                href="/hizmetlerimiz#eticaret"
                                class="inline-flex items-center text-sm font-medium text-green-600 hover:text-green-800">
                                Detayları İncele
                                <svg
                                    class="ml-1 h-4 w-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Mobil Uygulama -->
                <div
                    class="group relative overflow-hidden rounded-2xl bg-white p-8 shadow-lg transition-all duration-500 hover:-translate-y-3 hover:rotate-1 hover:shadow-2xl">
                    <div
                        class="absolute top-0 left-0 h-1 w-full bg-gradient-to-r from-purple-500 to-pink-600">
                    </div>
                    <div
                        class="absolute -top-10 -right-10 h-20 w-20 rounded-full bg-gradient-to-r from-purple-500 to-pink-600 opacity-10 transition-opacity duration-300 group-hover:opacity-20">
                    </div>
                    <div class="relative">
                        <div
                            class="mb-4 transform text-4xl transition-transform duration-300 group-hover:scale-110">
                            <svg
                                class="h-12 w-12 text-purple-600"
                                fill="currentColor"
                                viewBox="0 0 24 24">
                                <path
                                    d="M17 2H7C5.9 2 5 2.9 5 4V20C5 21.1 5.9 22 7 22H17C18.1 22 19 21.1 19 20V4C19 2.9 18.1 2 17 2ZM17 18H7V6H17V18Z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="mb-3 text-xl font-semibold text-gray-900 transition-colors duration-300 group-hover:text-purple-600">
                            Mobil Uygulama
                        </h3>
                        <p class="mb-4 text-gray-600">
                            iOS ve Android platformları için native uygulamalar
                            geliştiriyoruz.
                        </p>
                        <ul class="mb-6 space-y-2 text-sm text-gray-500">
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-purple-400"
                                ></span>
                                Native Geliştirme
                            </li>
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-purple-400"
                                ></span>
                                Cross Platform
                            </li>
                            <li class="flex items-center">
                                <span
                                    class="mr-2 h-2 w-2 rounded-full bg-purple-400"
                                ></span>
                                UI/UX Tasarım
                            </li>
                        </ul>
                        <div
                            class="opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                            <a
                                href="/hizmetlerimiz#mobil"
                                class="inline-flex items-center text-sm font-medium text-purple-600 hover:text-purple-800">
                                Detayları İncele
                                <svg
                                    class="ml-1 h-4 w-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TEKNOLOJİLER SECTION -->
    <section class="relative overflow-hidden bg-white py-24 lg:py-32">
        <!-- Background Pattern -->
        <div class="absolute inset-0 opacity-5">
            <div
                class="absolute inset-0"
                style="background-image: radial-gradient(circle at 2px 2px, rgba(0,0,0,.15) 1px, transparent 0); background-size: 40px 40px;">
            </div>
        </div>

        <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mb-16 text-center">
                <h2
                    class="mt-6 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Kullandığımız Teknolojiler
                </h2>
                <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
                    Modern ve güvenilir teknolojilerle projelerinizi gelişiyoruz
                </p>
            </div>

            <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-6">
                <!-- React -->
                <div
                    class="group flex flex-col items-center rounded-xl bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-blue-50 hover:shadow-lg">
                    <div
                        class="mb-3 transition-transform duration-300 group-hover:scale-110">
                        <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="12" r="3" fill="#61DAFB"
                            ></circle>
                            <ellipse
                                cx="12"
                                cy="12"
                                rx="10"
                                ry="4"
                                stroke="#61DAFB"
                                stroke-width="1.5"
                                fill="none"></ellipse>
                            <ellipse
                                cx="12"
                                cy="12"
                                rx="10"
                                ry="4"
                                stroke="#61DAFB"
                                stroke-width="1.5"
                                fill="none"
                                transform="rotate(60 12 12)"></ellipse>
                            <ellipse
                                cx="12"
                                cy="12"
                                rx="10"
                                ry="4"
                                stroke="#61DAFB"
                                stroke-width="1.5"
                                fill="none"
                                transform="rotate(-60 12 12)"></ellipse>
                        </svg>
                    </div>
                    <span
                        class="text-sm font-medium text-gray-700 transition-colors duration-300 group-hover:text-blue-600"
                        >React</span
                    >
                </div>

                <!-- Vue -->
                <div
                    class="group flex flex-col items-center rounded-xl bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-green-50 hover:shadow-lg">
                    <div
                        class="mb-3 transition-transform duration-300 group-hover:scale-110">
                        <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none">
                            <path d="M12 3L2 21h20L12 3z" fill="#4FC08D"></path>
                            <path d="M12 8L6 18h12L12 8z" fill="#35495E"></path>
                        </svg>
                    </div>
                    <span
                        class="text-sm font-medium text-gray-700 transition-colors duration-300 group-hover:text-green-600"
                        >Vue.js</span
                    >
                </div>

                <!-- Next.js -->
                <div
                    class="group flex flex-col items-center rounded-xl bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-gray-100 hover:shadow-lg">
                    <div
                        class="mb-3 transition-transform duration-300 group-hover:scale-110">
                        <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="12" r="11" fill="#000"></circle>
                            <path d="M9 9v6l6-6H9z" fill="#fff"></path>
                            <path d="M15 15h1V9h-1v6z" fill="#fff"></path>
                        </svg>
                    </div>
                    <span
                        class="text-sm font-medium text-gray-700 transition-colors duration-300 group-hover:text-gray-900"
                        >Next.js</span
                    >
                </div>

                <!-- TypeScript -->
                <div
                    class="group flex flex-col items-center rounded-xl bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-blue-50 hover:shadow-lg">
                    <div
                        class="mb-3 transition-transform duration-300 group-hover:scale-110">
                        <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none">
                            <rect
                                x="2"
                                y="2"
                                width="20"
                                height="20"
                                rx="2"
                                fill="#3178C6"></rect>
                            <text
                                x="12"
                                y="16"
                                text-anchor="middle"
                                fill="white"
                                font-family="Arial, sans-serif"
                                font-size="14"
                                font-weight="bold">TS</text
                            >
                        </svg>
                    </div>
                    <span
                        class="text-sm font-medium text-gray-700 transition-colors duration-300 group-hover:text-blue-600"
                        >TypeScript</span
                    >
                </div>

                <!-- Node.js -->
                <div
                    class="group flex flex-col items-center rounded-xl bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-green-50 hover:shadow-lg">
                    <div
                        class="mb-3 transition-transform duration-300 group-hover:scale-110">
                        <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none">
                            <path
                                d="M12 2L2 7v10l10 5 10-5V7l-10-5z"
                                fill="#68A063"></path>
                            <path d="M12 12L7 9v6l5-3z" fill="#fff"></path>
                            <path d="M12 12l5-3v6l-5-3z" fill="#c1c1c1"></path>
                        </svg>
                    </div>
                    <span
                        class="text-sm font-medium text-gray-700 transition-colors duration-300 group-hover:text-green-600"
                        >Node.js</span
                    >
                </div>

                <!-- AWS -->
                <div
                    class="group flex flex-col items-center rounded-xl bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-orange-50 hover:shadow-lg">
                    <div
                        class="mb-3 transition-transform duration-300 group-hover:scale-110">
