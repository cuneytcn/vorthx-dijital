---
import PageLayout from '../layout/page.layout.astro';
---

<PageLayout>
    <!-- HERO SECTION -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 py-24 lg:py-32">
        <!-- Background Animation Elements -->
        <div class="absolute inset-0">
            <div
                class="absolute top-10 left-10 h-20 w-20 animate-pulse rounded-full bg-white opacity-10">
            </div>
            <div
                class="absolute right-10 bottom-10 h-16 w-16 animate-pulse rounded-full bg-white opacity-10 delay-1000">
            </div>
            <div
                class="absolute top-1/2 left-1/4 h-12 w-12 animate-pulse rounded-full bg-white opacity-10 delay-500">
            </div>
            <div
                class="absolute top-20 right-1/4 h-24 w-24 animate-bounce rounded-full bg-white opacity-5 delay-300">
            </div>
        </div>

        <!-- Geometric Patterns -->
        <div class="absolute inset-0 opacity-10">
            <div
                class="animate-spin-slow absolute top-16 left-16 h-32 w-32 rotate-45 border-2 border-white">
            </div>
            <div
                class="absolute right-16 bottom-16 h-24 w-24 rotate-12 animate-pulse border-2 border-white">
            </div>
        </div>

        <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
            <div class="space-y-8">
                <div
                    class="inline-flex items-center rounded-full bg-white/20 px-4 py-2 text-sm font-medium text-white/90 backdrop-blur-sm">
                    <span class="mr-2">💰</span>
                    Şeffaf Fiyatlandırma
                </div>

                <h1
                    class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
                    <span class="block">Fiyatlandırma</span>
                    <span
                        class="block bg-gradient-to-r from-yellow-300 via-orange-300 to-pink-300 bg-clip-text text-transparent">
                        Herkes İçin Çözüm
                    </span>
                </h1>

                <p
                    class="mx-auto max-w-2xl text-xl leading-relaxed text-blue-100">
                    İhtiyacınıza uygun paket seçin. Tüm fiyatlarımız şeffaf,
                    gizli maliyet yok. Projenizi bugün başlatın.
                </p>
            </div>
        </div>
    </section>

    <!-- PRICING CARDS SECTION -->
    <section class="py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
                <h2
                    class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Paketlerimiz
                </h2>
                <p class="mt-6 text-lg leading-8 text-gray-600">
                    Size en uygun paketi seçin ve projenizi hayata geçirin
                </p>
            </div>

            <div class="mx-auto mt-16 max-w-2xl lg:max-w-none">
                <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                    <!-- BAŞLANGIÇ PAKETİ -->
                    <div
