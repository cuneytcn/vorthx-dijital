---
import { siteConfig } from '../config/site.config';
import PageLayout from '../layout/page.layout.astro';

const { contacts } = siteConfig;
---

<PageLayout>
    <!-- HERO SECTION -->
    <section
        class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 py-24 lg:py-32">
        <!-- Background Animation Elements -->
        <div class="absolute inset-0">
            <div
                class="absolute top-10 left-10 h-20 w-20 animate-pulse rounded-full bg-white opacity-10">
            </div>
            <div
                class="absolute right-10 bottom-10 h-16 w-16 animate-pulse rounded-full bg-white opacity-10 delay-1000">
            </div>
            <div
                class="absolute top-1/2 left-1/4 h-12 w-12 animate-pulse rounded-full bg-white opacity-10 delay-500">
            </div>
            <div
                class="absolute top-20 right-1/4 h-24 w-24 animate-bounce rounded-full bg-white opacity-5 delay-300">
            </div>
        </div>

        <!-- Geometric Patterns -->
        <div class="absolute inset-0 opacity-10">
            <div
                class="animate-spin-slow absolute top-16 left-16 h-32 w-32 rotate-45 border-2 border-white">
            </div>
            <div
                class="absolute right-16 bottom-16 h-24 w-24 rotate-12 animate-pulse border-2 border-white">
            </div>
        </div>

        <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
            <div class="space-y-8">
                <div
                    class="inline-flex items-center rounded-full bg-white/20 px-4 py-2 text-sm font-medium text-white/90 backdrop-blur-sm">
                    <span class="mr-2">📞</span>
                    Bize Ulaşın
                </div>

                <h1
                    class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
                    <span class="block">İletişime</span>
                    <span
                        class="block bg-gradient-to-r from-yellow-300 via-orange-300 to-pink-300 bg-clip-text text-transparent">
                        Geçin
                    </span>
                </h1>

                <p
                    class="mx-auto max-w-2xl text-xl leading-relaxed text-blue-100">
                    Projenizi konuşmak, sorularınızı cevaplamak ve size özel
                    çözümler geliştirmek için buradayız. Hemen iletişime geçin!
                </p>
            </div>
        </div>
    </section>

    <!-- CONTACT INFO & FORM SECTION -->
    <section class="py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="grid grid-cols-1 gap-16 lg:grid-cols-2">
                <!-- Contact Information -->
                <div class="space-y-12">
                    <div class="space-y-6">
                        <h2
                            class="text-3xl font-bold tracking-tight text-gray-900">
                            İletişim Bilgileri
                        </h2>
                        <p class="text-lg text-gray-600">
                            Size en hızlı şekilde dönüş yapabilmek için birden
                            fazla iletişim kanalımız bulunuyor.
                        </p>
                    </div>

                    <!-- Contact Cards -->
                    <div class="space-y-6">
                        <!-- Telefon -->
                        <div
                            class="flex items-start space-x-4 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-md">
                            <div class="flex-shrink-0">
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100">
                                    <svg
                                        class="h-6 w-6 text-indigo-600"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900">
                                    Telefon
                                </h3>
                                <p class="text-gray-600">
                                    Hızlı görüşme için arayın
                                </p>
                                <a
                                    href="tel:+905551234567"
                                    class="font-medium text-indigo-600 hover:text-indigo-800">
                                    +90 555 123 45 67
                                </a>
                            </div>
                        </div>

                        <!-- Email -->
                        <div
                            class="flex items-start space-x-4 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-purple-200 hover:shadow-md">
                            <div class="flex-shrink-0">
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100">
                                    <svg
                                        class="h-6 w-6 text-purple-600"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900">
                                    E-posta
                                </h3>
                                <p class="text-gray-600">
                                    Detaylı bilgi için yazın
                                </p>
                                <a
                                    href="mailto:info@vorthxdijital.com"
                                    class="font-medium text-purple-600 hover:text-purple-800">
                                    info@vorthxdijital.com
                                </a>
                            </div>
                        </div>

                        <!-- Adres -->
                        <div
                            class="flex items-start space-x-4 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-pink-200 hover:shadow-md">
                            <div class="flex-shrink-0">
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-lg bg-pink-100">
                                    <svg
                                        class="h-6 w-6 text-pink-600"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                                        ></path>
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900">
                                    Adres
                                </h3>
                                <p class="text-gray-600">
                                    Ofisimize ziyaret için
                                </p>
                                <address
                                    class="font-medium text-pink-600 not-italic">
                                    Maslak Mah. Büyükdere Cd.<br />
                                    No:123 K:5 D:12<br />
                                    Şişli/İstanbul
                                </address>
                            </div>
                        </div>

                        <!-- Çalışma Saatleri -->
                        <div
                            class="flex items-start space-x-4 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-green-200 hover:shadow-md">
                            <div class="flex-shrink-0">
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-lg bg-green-100">
                                    <svg
                                        class="h-6 w-6 text-green-600"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor">
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900">
                                    Çalışma Saatleri
                                </h3>
                                <p class="text-gray-600">
                                    Müsait olduğumuz zamanlar
                                </p>
                                <div class="font-medium text-green-600">
                                    <p>{contacts.hours.weekdays}</p>
                                    <p>{contacts.hours.other}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Social Media -->
                    <div class="space-y-6">
                        <h3 class="text-xl font-bold text-gray-900">
                            Sosyal Medya
                        </h3>
                        <div class="flex space-x-4">
                            <a
                                href="#"
                                class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-600 text-white transition-colors hover:bg-blue-700">
                                <svg
                                    class="h-6 w-6"
                                    fill="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"
                                    ></path>
                                </svg>
                            </a>
                            <a
                                href="#"
                                class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-500 text-white transition-colors hover:bg-blue-600">
                                <svg
                                    class="h-6 w-6"
                                    fill="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"
                                    ></path>
                                </svg>
                            </a>
                            <a
                                href="#"
                                class="flex h-12 w-12 items-center justify-center rounded-lg bg-pink-500 text-white transition-colors hover:bg-pink-600">
                                <svg
                                    class="h-6 w-6"
                                    fill="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.746-1.378l-.753 2.87c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"
                                    ></path>
                                </svg>
                            </a>
                            <a
                                href="#"
                                class="flex h-12 w-12 items-center justify-center rounded-lg bg-blue-700 text-white transition-colors hover:bg-blue-800">
                                <svg
                                    class="h-6 w-6"
                                    fill="currentColor"
                                    viewBox="0 0 24 24">
                                    <path
                                        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                    ></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Contact Form -->
                <div
                    class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
                    <div class="space-y-8">
                        <div class="space-y-4">
                            <h2
                                class="text-3xl font-bold tracking-tight text-gray-900">
                                Mesaj Gönder
                            </h2>
                            <p class="text-gray-600">
                                Formu doldurarak bize mesaj gönderin. En kısa
                                sürede size dönüş yapacağız.
                            </p>
                        </div>

                        <form class="space-y-6" action="#" method="POST">
                            <!-- Ad Soyad -->
                            <div>
                                <label
                                    for="name"
                                    class="mb-2 block text-sm font-medium text-gray-700">
                                    Ad Soyad *
                                </label>
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
                                    placeholder="Adınız ve soyadınız"
                                />
                            </div>

                            <!-- Email -->
                            <div>
                                <label
                                    for="email"
                                    class="mb-2 block text-sm font-medium text-gray-700">
                                    E-posta Adresi *
                                </label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
                                    placeholder="ornek@email.com"
                                />
                            </div>

                            <!-- Telefon -->
                            <div>
                                <label
                                    for="phone"
                                    class="mb-2 block text-sm font-medium text-gray-700">
                                    Telefon Numarası
                                </label>
                                <input
                                    type="tel"
                                    id="phone"
                                    name="phone"
                                    class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
                                    placeholder="+90 555 123 45 67"
                                />
                            </div>

                            <!-- Konu -->
                            <div>
                                <label
                                    for="subject"
                                    class="mb-2 block text-sm font-medium text-gray-700">
                                    Konu *
                                </label>
                                <select
                                    id="subject"
                                    name="subject"
                                    required
                                    class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                                    <option value="">Konu seçin</option>
                                    <option value="web-tasarim"
                                        >Web Tasarım</option
                                    >
                                    <option value="e-ticaret">E-ticaret</option>
                                    <option value="mobil-uygulama"
                                        >Mobil Uygulama</option
                                    >
                                    <option value="dijital-pazarlama"
                                        >Dijital Pazarlama</option
                                    >
                                    <option value="seo">SEO Hizmetleri</option>
                                    <option value="diger">Diğer</option>
                                </select>
                            </div>

                            <!-- Mesaj -->
                            <div>
                                <label
                                    for="message"
                                    class="mb-2 block text-sm font-medium text-gray-700">
                                    Mesajınız *
                                </label>
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="5"
                                    required
                                    class="w-full resize-none rounded-lg border border-gray-300 px-4 py-3 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
                                    placeholder="Projeniz hakkında detaylı bilgi verin..."
                                ></textarea>
                            </div>

                            <!-- KVKK Onayı -->
                            <div class="flex items-start space-x-2">
                                <input
                                    type="checkbox"
                                    id="privacy"
                                    name="privacy"
                                    required
                                    class="mt-1 h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
                                />
                                <label
                                    for="privacy"
                                    class="text-sm text-gray-600">
                                    <a
                                        href="#"
                                        class="text-indigo-600 hover:text-indigo-800"
                                        >Kişisel Verilerin Korunması</a
                                    >
                                    kapsamında verilerimin işlenmesini kabul ediyorum.
                                    *
                                </label>
                            </div>

                            <!-- Submit Button -->
                            <button
                                type="submit"
                                class="w-full rounded-lg bg-gradient-to-r from-indigo-600 to-purple-600 px-8 py-4 text-lg font-semibold text-white shadow-lg transition-all duration-200 hover:shadow-xl focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:outline-none">
                                Mesajı Gönder
                                <svg
                                    class="ml-2 inline h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.768 59.768 0 013.27 20.876L5.999 12zm0 0h7.5"
                                    ></path>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MAP SECTION -->
    <section class="bg-gray-50 py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto mb-16 max-w-2xl text-center">
                <h2
                    class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                    Ofisimizi Ziyaret Edin
                </h2>
                <p class="mt-6 text-lg leading-8 text-gray-600">
                    İstanbul Maslak'taki ofisimize kolayca ulaşabilirsiniz
                </p>
            </div>

            <!-- Map Placeholder -->
            <div class="aspect-[21/9] overflow-hidden rounded-2xl bg-gray-200">
                <div class="flex h-full items-center justify-center">
                    <div class="text-center text-gray-500">
                        <svg
                            class="mx-auto mb-4 h-16 w-16"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                            ></path>
                        </svg>
                        <p class="text-lg font-medium">
                            Google Maps Entegrasyonu
                        </p>
                        <p class="text-sm">Harita burada görüntülenecek</p>
                    </div>
                </div>
            </div>

            <!-- Location Details -->
            <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-3">
                <div class="text-center">
                    <div class="flex justify-center">
                        <div
                            class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100">
                            <svg
                                class="h-6 w-6 text-indigo-600"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M8.25 18.75a1.5 1.5 0 01-3 0V8.625a1.125 1.125 0 011.125-1.125h4.5V7.5a1.5 1.5 0 113 0v.375h4.5a1.125 1.125 0 011.125 1.125v10.125a1.5 1.5 0 01-3 0V10.5H8.25v8.25z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                    <h3 class="mt-4 text-lg font-semibold text-gray-900">
                        Metro
                    </h3>
                    <p class="text-gray-600">
                        4. Levent Metro İstasyonu<br />5 dakika yürüme mesafesi
                    </p>
                </div>

                <div class="text-center">
                    <div class="flex justify-center">
                        <div
                            class="flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100">
                            <svg
                                class="h-6 w-6 text-purple-600"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
